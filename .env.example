# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=upd
POSTGRES_PASSWORD=changeme
POSTGRES_DB=upd

# Собирается автоматически из переменных выше для docker-compose.
# Для локального запуска (tsx напрямую) — указать явно:
DATABASE_URL=postgres://upd:changeme@localhost:5432/upd

# ── Источник .lst ─────────────────────────────────────────────────────────────
# Вариант 1: ITS (production)
ITS_LOGIN=
ITS_PASSWORD=

# Вариант 2: локальный файл (dev-replay, без ITS)
# Положи v8cscdsc.lst в ./data/ и раскомментируй:
# LST_FILE=/data/v8cscdsc.lst

# ── Импорт ───────────────────────────────────────────────────────────────────
# Cron-расписание (default: каждый день в 04:00)
IMPORT_CRON=0 4 * * *

# Запустить импорт сразу при старте воркера (1 = да)
IMPORT_ON_START=1

# ── Веб ──────────────────────────────────────────────────────────────────────
# WEB_PORT — прямой порт для доступа без Caddy (например, в dev).
# При использовании Caddy (HTTPS) оставьте пустым — трафик идёт через :80/:443.
WEB_PORT=

# ── HTTPS / Caddy ─────────────────────────────────────────────────────────────
# DOMAIN задаётся через /admin → "Домен и HTTPS" — здесь для справки.
# CADDY_API — внутренний адрес Caddy Admin API (менять не нужно).
DOMAIN=
CADDY_API=http://caddy:2019

# ── Администраторская панель (/admin) ─────────────────────────────────────────
# Эти кредиты НЕ связаны с ИТС. Задаются при установке через deploy.sh.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=changeme
