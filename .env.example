# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=upd
POSTGRES_PASSWORD=changeme
POSTGRES_DB=upd

# Собирается автоматически из переменных выше для docker-compose.
# Для локального запуска (tsx напрямую) — указать явно:
DATABASE_URL=postgres://upd:changeme@localhost:5432/upd

# ── Источник .lst ─────────────────────────────────────────────────────────────
# Вариант 1: ITS (production)
ITS_LOGIN=
ITS_PASSWORD=

# Вариант 2: локальный файл (dev-replay, без ITS)
# Положи v8cscdsc.lst в ./data/ и раскомментируй:
# LST_FILE=/data/v8cscdsc.lst

# ── Импорт ───────────────────────────────────────────────────────────────────
# Cron-расписание (default: каждый день в 04:00)
IMPORT_CRON=0 4 * * *

# Запустить импорт сразу при старте воркера (1 = да)
IMPORT_ON_START=1

# ── Веб ──────────────────────────────────────────────────────────────────────
WEB_PORT=3000
